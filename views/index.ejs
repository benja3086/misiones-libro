<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Acceso</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;800&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:       #0a0a0f;
      --surface:  #111118;
      --border:   #1e1e2e;
      --accent:   #c8f060;
      --accent2:  #7effd4;
      --text:     #e8e8f0;
      --muted:    #5a5a72;
      --error:    #ff6b6b;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Syne', sans-serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(var(--border) 1px, transparent 1px),
        linear-gradient(90deg, var(--border) 1px, transparent 1px);
      background-size: 48px 48px;
      opacity: 0.4;
      pointer-events: none;
    }

    body::after {
      content: '';
      position: fixed;
      width: 600px; height: 600px;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      background: radial-gradient(circle, rgba(200,240,96,0.06) 0%, transparent 70%);
      pointer-events: none;
    }

    .card {
      position: relative;
      width: 420px;
      background: var(--surface);
      border: 1px solid var(--border);
      padding: 48px 40px 40px;
      animation: slideUp .5s cubic-bezier(.16,1,.3,1) both;
    }

    .card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--accent), var(--accent2));
    }

    @keyframes slideUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .logo {
      font-size: 11px;
      font-family: 'DM Mono', monospace;
      color: var(--muted);
      letter-spacing: .15em;
      text-transform: uppercase;
      margin-bottom: 32px;
    }

    .logo span { color: var(--accent); }

    .tabs {
      display: grid;
      grid-template-columns: 1fr 1fr;
      border: 1px solid var(--border);
      margin-bottom: 32px;
    }

    .tab-btn {
      background: none;
      border: none;
      color: var(--muted);
      font-family: 'Syne', sans-serif;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: .06em;
      text-transform: uppercase;
      padding: 12px;
      cursor: pointer;
      transition: color .2s, background .2s;
    }

    .tab-btn.active {
      background: var(--accent);
      color: #0a0a0f;
    }

    .form-panel { display: none; flex-direction: column; gap: 16px; }
    .form-panel.active { display: flex; }

    label {
      display: flex;
      flex-direction: column;
      gap: 6px;
      font-size: 11px;
      font-family: 'DM Mono', monospace;
      color: var(--muted);
      letter-spacing: .1em;
      text-transform: uppercase;
    }

    input {
      background: var(--bg);
      border: 1px solid var(--border);
      color: var(--text);
      font-family: 'DM Mono', monospace;
      font-size: 14px;
      padding: 12px 14px;
      outline: none;
      transition: border-color .2s;
    }

    input:focus { border-color: var(--accent); }
    input::placeholder { color: var(--muted); }

    .btn {
      margin-top: 8px;
      padding: 14px;
      border: none;
      cursor: pointer;
      font-family: 'Syne', sans-serif;
      font-size: 13px;
      font-weight: 800;
      letter-spacing: .1em;
      text-transform: uppercase;
      background: var(--accent);
      color: #0a0a0f;
      transition: opacity .2s, transform .1s;
    }

    .btn:hover   { opacity: .88; }
    .btn:active  { transform: scale(.98); }
    .btn:disabled { opacity: .4; cursor: not-allowed; }

    .msg {
      font-family: 'DM Mono', monospace;
      font-size: 12px;
      padding: 10px 12px;
      display: none;
      border-left: 3px solid;
    }

    .msg.success { border-color: var(--accent2); color: var(--accent2); background: rgba(126,255,212,.06); }
    .msg.error   { border-color: var(--error);   color: var(--error);   background: rgba(255,107,107,.06); }
    .msg.show    { display: block; }
  </style>
</head>
<body>

<div class="card">
  <div class="logo">node<span>/</span>auth</div>

  <div class="tabs">
    <button class="tab-btn active" onclick="switchTab('login')">Iniciar sesión</button>
    <button class="tab-btn"       onclick="switchTab('register')">Registrarse</button>
  </div>

  <!-- LOGIN -->
  <div id="loginPanel" class="form-panel active">
    <label>Usuario
      <input type="text" id="loginUser" placeholder="tu_usuario" autocomplete="username"/>
    </label>
    <label>Contraseña
      <input type="password" id="loginPass" placeholder="••••••••" autocomplete="current-password"/>
    </label>
    <div id="loginMsg" class="msg"></div>
    <button class="btn" onclick="handleLogin()">Entrar →</button>
  </div>

  <!-- REGISTER -->
  <div id="registerPanel" class="form-panel">
    <label>Usuario
      <input type="text" id="regUser" placeholder="nuevo_usuario" autocomplete="username"/>
    </label>
    <label>Contraseña
      <input type="password" id="regPass" placeholder="••••••••" autocomplete="new-password"/>
    </label>
    <div id="registerMsg" class="msg"></div>
    <button class="btn" onclick="handleRegister()">Crear cuenta →</button>
  </div>
</div>

<script>
  function switchTab(tab) {
    document.querySelectorAll('.tab-btn').forEach((b, i) =>
      b.classList.toggle('active', (tab === 'login') ? i === 0 : i === 1)
    );
    document.getElementById('loginPanel').classList.toggle('active', tab === 'login');
    document.getElementById('registerPanel').classList.toggle('active', tab === 'register');
    clearMsg('loginMsg');
    clearMsg('registerMsg');
  }

  function showMsg(id, type, text) {
    const el = document.getElementById(id);
    el.className = `msg ${type} show`;
    el.textContent = text;
  }

  function clearMsg(id) {
    const el = document.getElementById(id);
    el.className = 'msg';
    el.textContent = '';
  }

  async function handleLogin() {
    const username = document.getElementById('loginUser').value.trim();
    const password = document.getElementById('loginPass').value;
    if (!username || !password) return showMsg('loginMsg', 'error', 'Completá todos los campos.');

    const btn = document.querySelector('#loginPanel .btn');
    btn.disabled = true;

    try {
      const res = await fetch('/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username, password })
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Error al iniciar sesión');
      showMsg('loginMsg', 'success', `Bienvenido, ${data.user.username ?? username}`);
      setTimeout(() => window.location.href = '/protected', 900);
    } catch (err) {
      showMsg('loginMsg', 'error', err.message);
    } finally {
      btn.disabled = false;
    }
  }

  async function handleRegister() {
    const username = document.getElementById('regUser').value.trim();
    const password = document.getElementById('regPass').value;
    if (!username || !password) return showMsg('registerMsg', 'error', 'Completá todos los campos.');

    const btn = document.querySelector('#registerPanel .btn');
    btn.disabled = true;

    try {
      const res = await fetch('/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username, password })
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Error al registrarse');
      showMsg('registerMsg', 'success', `Cuenta creada. ID: ${data.id}`);
      setTimeout(() => switchTab('login'), 1200);
    } catch (err) {
      showMsg('registerMsg', 'error', err.message);
    } finally {
      btn.disabled = false;
    }
  }
</script>

</body>
</html>